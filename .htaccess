Options -Indexes
DirectoryIndex index.php index.html

RewriteEngine On
RewriteBase /

# Force HTTPS (uncomment on production)
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove trailing slash (except root)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [R=301,L]

# Route clean URLs to index.php in matching subdirectory
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/%{REQUEST_URI}/index.php -f
RewriteRule ^(.*)$ %{DOCUMENT_ROOT}/$1/index.php [L]

# Custom error pages
ErrorDocument 404 /404/index.php

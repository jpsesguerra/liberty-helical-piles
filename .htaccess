Options -Indexes
DirectoryIndex index.php index.html

RewriteEngine On
RewriteBase /

# 301 redirects — preserve SEO from old URL structure
Redirect 301 /installer /become-an-installer
Redirect 301 /service /services
Redirect 301 /service/helical-pile-piers-installation /services/helical-pile-installation
Redirect 301 /service/foundation-underpinning-repair /services/underpinning-repair
Redirect 301 /service/equipment-rentals-sale /services/equipment-rentals
Redirect 301 /service/custom-fabrication /services/custom-fabrication

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove trailing slash (except root)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [R=301,L]

# Route clean URLs to index.php in matching subdirectory
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/%{REQUEST_URI}/index.php -f
RewriteRule ^(.*)$ %{DOCUMENT_ROOT}/$1/index.php [L]

# Custom error pages
ErrorDocument 404 /404/index.php
